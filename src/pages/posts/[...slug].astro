---
import { getCollection } from "astro:content";
import Post from "../../layouts/Post.astro";

export async function getStaticPaths() {
  const all = await getCollection("posts", ({ data }) => !data.draft);
  return all.map((post) => {
    // prev/next navigate WITHIN the post's own series, ordered by part
    const siblings = all
      .filter((p) => p.data.series === post.data.series)
      .sort((a, b) => a.data.part - b.data.part);
    const i = siblings.findIndex((p) => p.slug === post.slug);
    return {
      params: { slug: post.slug },
      props: { post, prev: siblings[i - 1], next: siblings[i + 1] },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await post.render();
---

<Post post={post} prev={prev} next={next}>
  <Content />
</Post>
