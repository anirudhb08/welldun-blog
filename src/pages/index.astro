---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { series as allSeries, seriesBySlug } from "../series";
import { SITE } from "../site";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf() || a.data.part - b.data.part,
);
const countFor = (slug: string) => posts.filter((p) => p.data.series === slug).length;
const fmt = (d: Date) => d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const site = SITE.url;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: site,
    description: SITE.description,
    publisher: { "@type": "Organization", name: SITE.name, url: site },
  },
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: SITE.name,
    url: site,
    blogPost: posts.slice(0, 10).map((p) => ({
      "@type": "BlogPosting",
      headline: p.data.title,
      datePublished: p.data.date.toISOString(),
      url: new URL(`/posts/${p.slug}/`, site).toString(),
    })),
  },
];
---

<Base title={`${SITE.name} — ${SITE.tagline}`} jsonLd={jsonLd}>
  <section class="wrap">
    <div class="hero">
      <p class="eyebrow kicker rise">welldun · software × AI</p>
      <h1 class="rise rise-2">
        Building at the seam of <span class="ital">software and AI</span>.
      </h1>
      <p class="dek rise rise-3">
        welldun is where I build practical, multi-tenant infrastructure — and write up how it
        actually works. Field notes on the bets, the gotchas, and the things you only learn
        by shipping and measuring.
      </p>
    </div>

    <hr class="rule" />

    <div class="section-head" id="projects">
      <h2 class="section-title">What I'm building</h2>
      <span class="section-note">projects, written up as series</span>
    </div>
    <div class="series-grid">
      {allSeries.map((s) => {
        const n = countFor(s.slug);
        const planned = s.status === "planned" || n === 0;
        return planned ? (
          <div class="series-card planned">
            <div class="series-top">
              <span class="series-name">{s.title}</span>
              <span class="series-count mono">soon</span>
            </div>
            <p class="series-dek">{s.dek}</p>
          </div>
        ) : (
          <a class="series-card" href={`/series/${s.slug}/`}>
            <div class="series-top">
              <span class="series-name">{s.title}</span>
              <span class="series-count mono">{n} part{n === 1 ? "" : "s"}</span>
            </div>
            <p class="series-dek">{s.dek}</p>
            <span class="series-go mono">Read the series →</span>
          </a>
        );
      })}
    </div>

    <hr class="rule-dash" />

    <div class="section-head">
      <h2 class="section-title">Latest writing</h2>
      <span class="section-note">{posts.length} posts</span>
    </div>
    <nav class="toc">
      {posts.map((p) => (
        <a class="entry" href={`/posts/${p.slug}/`}>
          <span class="entry-no mono">{seriesBySlug[p.data.series]?.title ?? p.data.series}</span>
          <div class="entry-body">
            <h2>{p.data.title}</h2>
            <p class="dek">{p.data.dek}</p>
          </div>
          <span class="entry-meta">{p.data.readingTime ?? ""}<br />{fmt(p.data.date)}</span>
        </a>
      ))}
    </nav>

    <hr class="rule-dash" />

    <div class="aside">
      <span class="label">About welldun</span>
      A one-builder lab for software + AI infrastructure — multi-tenant by default, with
      security and reliability treated as features, and AI used where it earns its place.
      <a href="/about/">More about welldun and me →</a>
    </div>
  </section>
</Base>
