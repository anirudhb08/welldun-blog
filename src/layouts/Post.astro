---
import Base from "./Base.astro";
import type { CollectionEntry } from "astro:content";
import { seriesBySlug } from "../series";
import { SITE } from "../site";

interface Props {
  post: CollectionEntry<"posts">;
  prev?: CollectionEntry<"posts">;
  next?: CollectionEntry<"posts">;
}
const { post, prev, next } = Astro.props;
const { title, dek, series, part, date, readingTime, tags } = post.data;
const fmtDate = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const partLabel = part === 0 ? "Series intro" : `Part ${part}`;
const s = seriesBySlug[series];

const url = new URL(`/posts/${post.slug}/`, Astro.site).toString();
const ogImage = `/og/posts/${post.slug}.png`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: dek,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: { "@type": "Person", name: SITE.author, url: SITE.authorUrl },
  publisher: { "@type": "Organization", name: SITE.name, url: SITE.url },
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  url,
  image: new URL(ogImage, Astro.site).toString(),
  articleSection: s?.title ?? series,
  keywords: tags.join(", "),
  isPartOf: { "@type": "CreativeWorkSeries", name: s?.title ?? series },
};
---

<Base
  title={`${title} · ${s?.title ?? "Notebook"}`}
  description={dek}
  ogType="article"
  image={ogImage}
  publishedTime={date}
  tags={tags}
  jsonLd={jsonLd}
>
  <article>
    <div class="wrap">
      <header class="article-head rise">
        <span class="eyebrow">
          <a href={`/series/${series}/`} class="crumb">{s?.title ?? series}</a> — {partLabel}
        </span>
        <h1>{title}</h1>
        <p class="dek">{dek}</p>
        <div class="article-meta">
          <span>{fmtDate}</span>
          {readingTime && <span>· {readingTime}</span>}
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="prose rise rise-2">
        <slot />
      </div>

      <nav class="pager">
        {prev ? (
          <a href={`/posts/${prev.slug}/`}>
            <span class="dir">← Previous</span>
            <span class="t">{prev.data.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="next" href={`/posts/${next.slug}/`}>
            <span class="dir">Next →</span>
            <span class="t">{next.data.title}</span>
          </a>
        ) : <span />}
      </nav>
    </div>
  </article>
</Base>
